        auto techList = player.get("techniques");
        auto i = 0;
        while (i < size(techniques)) {
            auto tech = techniques[i];
            auto owned = false;
            auto j = 0;
            while (j < size(techList)) {
                if (techList.get(j).equals(tech[0])) {
                    owned = true;
                    break;
                }
                j = j + 1;
            }
            if (!owned) {
                println((i + 1) + "." + tech[0] + " [" + tech[1] + "] - " + tech[2] + "灵石");
            }
            i = i + 1;
        }
        println("0.返回");
        print("> ");
        auto buy = Integer.parseInt(readLine());
        if (buy > 0 && buy <= size(techniques)) {
            auto tech = techniques[buy - 1];
            if (player.get("spiritStones") >= tech[2]) {
                player.put("spiritStones", player.get("spiritStones") - tech[2]);
                techList.add(tech[0]);
                println("习得功法: " + tech[0]);
                println("效果: " + tech[4]);
            } else {
                println("灵石不足！");
            }
        }
        
    } else if (choice == 3) {
        println("【法宝】");
        auto i = 0;
        while (i < size(artifacts)) {
            auto art = artifacts[i];
            auto price = (i + 1) * 100;
            println((i + 1) + "." + art[0] + " [" + art[1] + "] 攻+" + art[2] + " 防+" + art[3] + " - " + price + "灵石");
            i = i + 1;
        }
        println("0.返回");
        print("> ");
        auto buy = Integer.parseInt(readLine());
        if (buy > 0 && buy <= size(artifacts)) {
            auto art = artifacts[buy - 1];
            auto price = buy * 100;
            if (player.get("spiritStones") >= price) {
                player.put("spiritStones", player.get("spiritStones") - price);
                auto artList = player.get("artifacts");
                artList.add(art);
                player.put("attack", player.get("attack") + art[2]);
                player.put("defense", player.get("defense") + art[3]);
                player.put("spiritDefense", player.get("spiritDefense") + art[4]);
                println("获得法宝: " + art[0]);
            } else {
                println("灵石不足！");
            }
        }
        
    } else if (choice == 4) {
        auto matMap = player.get("materials");
        println("【出售材料】");
        auto i = 0;
        while (i < size(materials)) {
            auto mat = materials[i];
            auto count = matMap.get(mat[0]);
            if (count != null && count > 0) {
                println((i + 1) + "." + mat[0] + " x" + count + " - " + mat[2] + "灵石/个");
            }
            i = i + 1;
        }
        println("0.返回");
        print("> ");
        auto sell = Integer.parseInt(readLine());
        if (sell > 0 && sell <= size(materials)) {
            auto mat = materials[sell - 1];
            auto count = matMap.get(mat[0]);
            if (count != null && count > 0) {
                matMap.put(mat[0], count - 1);
                player.put("spiritStones", player.get("spiritStones") + mat[2]);
                println("出售成功！获得" + mat[2] + "灵石");
            }
        }
    }
};

