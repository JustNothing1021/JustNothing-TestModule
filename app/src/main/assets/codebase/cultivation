auto explore = () -> {
    println("");
    println("═══ 探索 " + locations[currentLocation][0] + " ═══");
    println(locations[currentLocation][1]);
    
    auto roll = random.nextInt(100);
    
    if (roll < 35) {
        auto dangerLevel = currentLocation + 1;
        auto maxEnemyIdx = Math.min(dangerLevel * 2, size(enemies)) - 1;
        auto enemyIdx = random.nextInt(maxEnemyIdx + 1);
        battle(enemies[enemyIdx]);
        
    } else if (roll < 55) {
        auto stones = (currentLocation + 1) * 5 + random.nextInt(20);
        player.put("spiritStones", player.get("spiritStones") + stones);
        println("发现灵石矿脉！获得" + stones + "灵石");
        
    } else if (roll < 70) {
        auto matIdx = random.nextInt(size(materials));
        auto mat = materials[matIdx];
        auto matMap = player.get("materials");
        auto count = matMap.get(mat[0]);
        if (count == null) count = 0;
        matMap.put(mat[0], count + 1);
        println("采集到: " + mat[0]);
        
    } else if (roll < 85) {
        auto cultGain = (currentLocation + 1) * 5 + random.nextInt(20);
        gainCultivation(cultGain);
        println("感悟天地，获得" + cultGain + "修为");
        
    } else if (roll < 95) {
        auto goldFind = (currentLocation + 1) * 10 + random.nextInt(50);
        player.put("gold", player.get("gold") + goldFind);
        println("发现宝藏！获得" + goldFind + "金币");
        
    } else {
        println("什么也没发现...");
    }
    
    day = day + 1;
    if (day % 30 == 0) {
        player.put("age", player.get("age") + 1);
        println("");
        println("又过了一年，你现在是" + player.get("age") + "岁");
        
        if (player.get("age") >= player.get("lifespan")) {
            println("");
            println("═══════════════════════════════════════");
            println("寿元耗尽，你已陨落...");
            println("═══════════════════════════════════════");
            gameRunning = false;
        }
    }
};

