auto usePill = () -> {
    println("");
    println("═══ 使用丹药 ═══");
    auto pillMap = player.get("pills");
    auto hasPill = false;
    auto i = 0;
    while (i < size(pills)) {
        auto pill = pills[i];
        auto count = pillMap.get(pill[0]);
        if (count != null && count > 0) {
            println((i + 1) + "." + pill[0] + " x" + count + " - " + pill[2]);
            hasPill = true;
        }
        i = i + 1;
    }
    println("0.返回");
    if (!hasPill) {
        println("没有丹药！");
        return;
    }
    print("> ");
    auto use = Integer.parseInt(readLine());
    if (use > 0 && use <= size(pills)) {
        auto pill = pills[use - 1];
        auto count = pillMap.get(pill[0]);
        if (count != null && count > 0) {
            pillMap.put(pill[0], count - 1);
            
            if (pill[3].equals("hp")) {
                player.put("hp", Math.min(player.get("hp") + pill[1], player.get("maxHp")));
                println("恢复" + pill[1] + "点生命！");
            } else if (pill[3].equals("mp")) {
                player.put("mp", Math.min(player.get("mp") + pill[1], player.get("maxMp")));
                println("恢复" + pill[1] + "点灵力！");
            } else if (pill[3].equals("cultivation")) {
                auto gain = 0;
                if (pill[0].equals("筑基丹")) gain = 500;
                else if (pill[0].equals("金丹")) gain = 2000;
                else if (pill[0].equals("元婴丹")) gain = 8000;
                gainCultivation(gain);
                println("获得" + gain + "修为！");
            } else if (pill[3].equals("permanent")) {
                player.put("attack", player.get("attack") + 5);
                player.put("defense", player.get("defense") + 5);
                println("永久增加5点攻击和防御！");
            } else if (pill[3].equals("lifespan")) {
                player.put("lifespan", player.get("lifespan") + 10);
                println("寿命增加10年！");
            }
        }
    }
};

auto tribulation = () -> {
    auto realmIdx = 0;
    auto r = 0;
    while (r < size(realms)) {
        if (realms[r].equals(player.get("realm"))) {
            realmIdx = r;
            break;
        }
        r = r + 1;
    }
    
    if (realmIdx < size(realms) - 2) {
        println("你的境界还不够，无法渡劫！");
        return;
    }
    
    if (!player.get("realm").equals("渡劫")) {
        println("你需要先达到渡劫期才能渡劫！");
        return;
    }
    
    println("");
    println("╔════════════════════════════════════════╗");
    println("║              天 劫 降 临               ║");
    println("╚════════════════════════════════════════╝");
    println("");
    println("九天之上，雷云密布...");
    Thread.sleep(1000);
    
    auto successChance = 30 + player.get("realmLevel") * 5;
    auto techList = player.get("techniques");
    auto t = 0;
    while (t < size(techList)) {
        if (techList.get(t).equals("天道法则")) {
            successChance = successChance + 20;
        }
        t = t + 1;
    }
    
    auto roll = random.nextInt(100);
    println("渡劫成功率: " + successChance + "%");
    Thread.sleep(500);
    println("天雷轰下！！！");
    Thread.sleep(500);
    
    if (roll < successChance) {
        println("");
        println("╔════════════════════════════════════════╗");
        println("║          ★★★ 渡劫成功！★★★            ║");
        println("║        你已飞升成仙！                  ║");
        println("╚════════════════════════════════════════╝");
        gameRunning = false;
    } else {
        println("");
        println("渡劫失败！身受重伤！");
        player.put("hp", 1);
        player.put("cultivation", player.get("cultivation") / 2);
        player.put("lifespan", player.get("lifespan") - 50);
        println("修为减半，寿命减少50年！");
    }
};

