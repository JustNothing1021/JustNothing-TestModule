auto gainExp = (amount) -> {
    auto exp = player.get("exp") + amount;
    player.put("exp", exp);
    
    while (player.get("exp") >= player.get("expToNext")) {
        player.put("exp", player.get("exp") - player.get("expToNext"));
        player.put("expToNext", Math.round(player.get("expToNext") * 1.5));
        player.put("attack", player.get("attack") + 2);
        player.put("defense", player.get("defense") + 1);
        player.put("maxHp", player.get("maxHp") + 10);
        player.put("hp", player.get("maxHp"));
        player.put("maxMp", player.get("maxMp") + 5);
        player.put("mp", player.get("maxMp"));
        player.put("realmLevel", player.get("realmLevel") + 1);
        println("");
        println("★ 境界提升！现在是【" + player.get("realm") + "】第" + player.get("realmLevel") + "层！");
    }
};

auto gainCultivation = (amount) -> {
    auto cult = player.get("cultivation") + amount;
    player.put("cultivation", cult);
    
    while (player.get("cultivation") >= player.get("cultivationToNext")) {
        auto realmIdx = 0;
        auto r = 0;
        while (r < size(realms)) {
            if (realms[r].equals(player.get("realm"))) {
                realmIdx = r;
                break;
            }
            r = r + 1;
        }
        
        if (realmIdx >= size(realms) - 1) {
            println("");
            println("╔════════════════════════════════════════╗");
            println("║          ★★★ 恭喜飞升！★★★            ║");
            println("║        你已成就仙人果位！              ║");
            println("╚════════════════════════════════════════╝");
            gameRunning = false;
            return;
        }
        
        player.put("cultivation", player.get("cultivation") - player.get("cultivationToNext"));
        player.put("cultivationToNext", Math.round(player.get("cultivationToNext") * 2));
        
        auto newRealm = realms[realmIdx + 1];
        auto bonus = realmBonus[realmIdx + 1];
        
        player.put("realm", newRealm);
        player.put("attack", player.get("attack") + bonus * 5);
        player.put("defense", player.get("defense") + bonus * 3);
        player.put("spirit", player.get("spirit") + bonus * 4);
        player.put("spiritDefense", player.get("spiritDefense") + bonus * 2);
        player.put("maxHp", player.get("maxHp") + bonus * 20);
        player.put("maxMp", player.get("maxMp") + bonus * 15);
        player.put("hp", player.get("maxHp"));
        player.put("mp", player.get("maxMp"));
        player.put("lifespan", player.get("lifespan") + 100);
        
        println("");
        println("╔════════════════════════════════════════╗");
        println("║          ★★★ 突破成功！★★★            ║");
        println("║      恭喜晋升【" + newRealm + "】境界！          ║");
        println("╚════════════════════════════════════════╝");
    }
};

auto battle = (enemy) -> {
    auto name = enemy[0];
    auto eHp = enemy[1];
    auto eAtk = enemy[2];
    auto eDef = enemy[3];
    auto eSpiritAtk = enemy[4];
    auto eExp = enemy[5];
    auto eStones = enemy[6];
    auto eType = enemy[7];
    
    println("");
    println("═══════════════════════════════════════");
    println("遭遇 " + name + "！");
    println("═══════════════════════════════════════");
    
    while (eHp > 0 && player.get("hp") > 0) {
        println("");
        println("【" + name + "】HP:" + eHp);
        println("【你】HP:" + player.get("hp") + "/" + player.get("maxHp") + " MP:" + player.get("mp") + "/" + player.get("maxMp"));
        println("1.攻击 2.法术 3.丹药 4.逃跑");
        print("> ");
        auto choice = Integer.parseInt(readLine());
        
        if (choice == 1) {
            auto dmg = player.get("attack") - eDef / 2;
            if (dmg < 1) dmg = 1;
            dmg = dmg + random.nextInt(5);
            eHp = eHp - dmg;
            println("你造成 " + dmg + " 点伤害！");
            
            if (eHp <= 0) break;
            
            auto eDmg = eAtk - player.get("defense") / 2;
            if (eDmg < 1) eDmg = 1;
            eDmg = eDmg + random.nextInt(3);
            player.put("hp", player.get("hp") - eDmg);
            println(name + "反击造成 " + eDmg + " 点伤害！");
            
        } else if (choice == 2) {
            if (player.get("mp") < 10) {
                println("灵力不足！");
                continue;
            }
            player.put("mp", player.get("mp") - 10);
            auto dmg = player.get("spirit") * 2 - eDef;
            if (dmg < 5) dmg = 5;
            dmg = dmg + random.nextInt(10);
            eHp = eHp - dmg;
            println("你施展法术造成 " + dmg + " 点伤害！");
            
            if (eHp <= 0) break;
            
            if (eSpiritAtk > 0) {
                auto eSpDmg = eSpiritAtk - player.get("spiritDefense");
                if (eSpDmg < 1) eSpDmg = 1;
                player.put("hp", player.get("hp") - eSpDmg);
                println(name + "施展法术造成 " + eSpDmg + " 点伤害！");
            }
            
        } else if (choice == 3) {
            auto pillMap = player.get("pills");
            println("可用丹药:");
            auto hasPill = false;
            auto idx = 1;
            auto pIdx = 0;
            while (pIdx < size(pills)) {
                auto pill = pills[pIdx];
                if (pill[3].equals("hp") || pill[3].equals("mp")) {
                    auto count = pillMap.get(pill[0]);
                    if (count != null && count > 0) {
                        println(idx + "." + pill[0] + " x" + count);
                        hasPill = true;
                        idx = idx + 1;
                    }
                }
                pIdx = pIdx + 1;
            }
            println("0.取消");
            if (!hasPill) {
                println("没有可用丹药！");
                continue;
            }
            print("> ");
            auto usePill = Integer.parseInt(readLine());
            if (usePill < 1) continue;
            
            auto used = 0;
            auto pIdx2 = 0;
            while (pIdx2 < size(pills) && used < usePill) {
                auto pill = pills[pIdx2];
                if (pill[3].equals("hp") || pill[3].equals("mp")) {
                    auto count = pillMap.get(pill[0]);
                    if (count != null && count > 0) {
                        used = used + 1;
                        if (used == usePill) {
                            pillMap.put(pill[0], count - 1);
                            if (pill[3].equals("hp")) {
                                player.put("hp", Math.min(player.get("hp") + pill[1], player.get("maxHp")));
                                println("恢复" + pill[1] + "点生命！");
                            } else {
                                player.put("mp", Math.min(player.get("mp") + pill[1], player.get("maxMp")));
                                println("恢复" + pill[1] + "点灵力！");
                            }
                        }
                    }
                }
                pIdx2 = pIdx2 + 1;
            }
            
        } else if (choice == 4) {
            if (random.nextInt(100) < 30) {
                println("逃跑失败！");
                auto eDmg = eAtk;
                player.put("hp", player.get("hp") - eDmg);
                println("被追击造成 " + eDmg + " 点伤害！");
            } else {
                println("成功逃跑！");
                return;
            }
        }
    }
    
    if (player.get("hp") <= 0) {
        println("");
        println("═══════════════════════════════════════");
        println("你被击败了...");
        println("═══════════════════════════════════════");
        player.put("hp", 1);
        player.put("gold", Math.max(0, player.get("gold") - 20));
        player.put("spiritStones", Math.max(0, player.get("spiritStones") - 5));
        return;
    }
    
    println("");
    println("═══════════════════════════════════════");
    println("击败 " + name + "！");
    println("获得 " + eExp + " 经验，" + eStones + " 灵石");
    println("═══════════════════════════════════════");
    
    gainExp(eExp);
    player.put("spiritStones", player.get("spiritStones") + eStones);
    player.put("kills", player.get("kills") + 1);
    
    if (random.nextInt(100) < 40) {
        auto matIdx = random.nextInt(size(materials));
        auto mat = materials[matIdx];
        auto matMap = player.get("materials");
        auto count = matMap.get(mat[0]);
        if (count == null) count = 0;
        matMap.put(mat[0], count + 1);
        println("获得材料: " + mat[0]);
    }
    
    if (random.nextInt(100) < 15) {
        auto pillIdx = random.nextInt(4);
        auto pill = pills[pillIdx];
        auto pillMap = player.get("pills");
        auto count = pillMap.get(pill[0]);
        if (count == null) count = 0;
        pillMap.put(pill[0], count + 1);
        println("获得丹药: " + pill[0]);
    }
};

