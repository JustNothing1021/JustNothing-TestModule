<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Hook ID + 状态 -->
            <TextView
                android:id="@+id/tv_detail_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textStyle="bold"
                android:textColor="@color/yellow" />

            <TextView
                android:id="@+id/tv_detail_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/light_green" />

            <!-- 基本信息网格 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analysis_hook_detail_status"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@android:color/darker_gray" />

                    <TextView
                        android:id="@+id/tv_detail_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analysis_hook_detail_call_count"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@android:color/darker_gray" />

                    <TextView
                        android:id="@+id/tv_detail_call_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analysis_hook_detail_create_time"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@android:color/darker_gray" />

                    <TextView
                        android:id="@+id/tv_detail_create_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analysis_hook_detail_signature"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@android:color/darker_gray" />

                    <TextView
                        android:id="@+id/tv_detail_signature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                </LinearLayout>

            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:background="#1AFFFFFF" />

            <!-- 代码预览区域 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/analysis_hook_detail_code_before"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textStyle="bold"
                android:textColor="@color/magenta"
                android:visibility="gone"
                android:id="@+id/label_before_code" />

            <TextView
                android:id="@+id/tv_detail_before_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:textColor="#CCFFFFFF"
                android:background="#0DFFFFFF"
                android:padding="8dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/analysis_hook_detail_code_after"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textStyle="bold"
                android:textColor="@color/magenta"
                android:visibility="gone"
                android:id="@+id/label_after_code" />

            <TextView
                android:id="@+id/tv_detail_after_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:textColor="#CCFFFFFF"
                android:background="#0DFFFFFF"
                android:padding="8dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/analysis_hook_detail_code_replace"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textStyle="bold"
                android:textColor="@color/magenta"
                android:visibility="gone"
                android:id="@+id/label_replace_code" />

            <TextView
                android:id="@+id/tv_detail_replace_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:textColor="#CCFFFFFF"
                android:background="#0DFFFFFF"
                android:padding="8dp"
                android:visibility="gone" />

            <!-- 输出日志 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/analysis_hook_detail_output_log"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textStyle="bold"
                android:textColor="@color/cyan" />

            <TextView
                android:id="@+id/tv_detail_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:textColor="#AAFFFFFF"
                android:minHeight="60dp"
                android:background="#0DFFFFFF"
                android:padding="8dp" />

            <!-- 操作按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_remove"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/analysis_hook_detail_btn_remove"
                    app:icon="@android:drawable/ic_menu_delete"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_toggle_enable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/analysis_hook_detail_btn_disable"
                    app:icon="@android:drawable/ic_media_pause"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_output"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/analysis_hook_detail_btn_output"
                    app:icon="@android:drawable/ic_menu_rotate"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
